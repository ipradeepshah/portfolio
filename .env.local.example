# ── Resend Email API ──────────────────────────────────────────
# Get free API key at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Blog Admin Password ───────────────────────────────────────
# Change this to something strong before deploying!
ADMIN_PASSWORD=YourStrongPassword2025

# ── Google Site Verification ──────────────────────────────────
# Get from: https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=your_verification_code_here

# ── Vercel Blob Storage ───────────────────────────────────────
# Auto-added by Vercel when you enable Blob Storage (see setup guide)
# Leave blank for local development — uses local JSON file instead
BLOB_READ_WRITE_TOKEN=
